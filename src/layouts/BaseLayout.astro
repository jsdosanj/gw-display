---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Premium bilingual kiosk display for Panj Pyare and Panj Takht." />
    <meta name="theme-color" content="#091322" />
    <meta name="application-name" content="Legacy of the Khalsa" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Legacy of the Khalsa" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="msapplication-TileColor" content="#091322" />
    <link rel="manifest" href="manifest.webmanifest" />
    <link rel="icon" href="icons/icon-192.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="icons/icon-192.svg" />
    <title>{title}</title>
    <meta property="og:title" content="Legacy of the Khalsa — Panj Pyare & Panj Takht" />
    <meta property="og:description" content="An interactive premium kiosk display exploring the Panj Pyare and the Panj Takht — the Five Beloved Ones and Five Sacred Seats of Sikh authority." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://gw-display.jasvant-dosanjh.workers.dev/" />
    <meta property="og:image" content="https://gw-display.jasvant-dosanjh.workers.dev/icons/icon-512.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="keywords" content="Panj Pyare, Panj Takht, Sikhi, Khalsa, Sikh history, Guru Gobind Singh, interactive display, gurdwara kiosk" />
    <link rel="canonical" href="https://gw-display.jasvant-dosanjh.workers.dev/" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Inter:wght@400;500;600;700;800&family=Mukta+Mahee:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
