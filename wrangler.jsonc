{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-07-17",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "gw-display",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist/client",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
